{
  "name": "jota-ai-launcher",
  "version": "0.1.0",
  "description": "Panel de lanzamiento y mantenimiento para Codex, Claude Code y OpenCode en Windows.",
  "main": "dist/main/main.js",
  "author": "Jota",
  "license": "MIT",
  "scripts": {
    "build:icon": "node scripts/build-icon.mjs",
    "prebuild": "npm run build:icon",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "npm run build:main && node --test tests/*.test.cjs",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run typecheck && npm run build:main && npm run build:renderer",
    "dist:win": "npm run build && electron-builder --win nsis",
    "start": "electron ."
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "sharp": "^0.35.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "wait-on": "latest"
  },
  "build": {
    "appId": "com.jota.ailauncher",
    "productName": "Jota AI Launcher",
    "artifactName": "Jota-AI-Launcher-Setup-${version}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Jota AI Launcher"
    },
    "publish": {
      "provider": "github",
      "owner": "JotaEse68",
      "repo": "jota-ai-launcher"
    }
  }
}

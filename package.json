{
  "name": "jota-ai-launcher",
  "version": "0.6.0",
  "description": "Multilingual desktop launcher for Codex, Claude Code and OpenCode on Windows and macOS.",
  "main": "dist/main/main.js",
  "author": "Jota",
  "license": "MIT",
  "homepage": "https://github.com/JotaEse68/jota-ai-launcher#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/JotaEse68/jota-ai-launcher.git"
  },
  "bugs": {
    "url": "https://github.com/JotaEse68/jota-ai-launcher/issues"
  },
  "scripts": {
    "build:icon": "node scripts/build-icon.mjs",
    "prebuild": "npm run build:icon",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "site:check": "node scripts/check-site.mjs",
    "test": "npm run build:main && node --test tests/*.test.cjs",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run typecheck && npm run build:main && npm run build:renderer",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --universal --publish never",
    "start": "electron ."
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.2.4",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "sharp": "^0.35.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.jota.ailauncher",
    "productName": "Jota AI Launcher",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "Jota-AI-Launcher-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "artifactName": "Jota-AI-Launcher-${version}-${arch}.${ext}",
      "category": "public.app-category.developer-tools",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Jota AI Launcher"
    },
    "publish": {
      "provider": "github",
      "owner": "JotaEse68",
      "repo": "jota-ai-launcher"
    }
  }
}
